# Agile360 – Variáveis de ambiente (cópia para .env e preencher)
# Nunca commitar .env com valores reais.

# Supabase PostgreSQL
ConnectionStrings__Supabase=Host=<project>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<password>;SSL Mode=Require;Trust Server Certificate=true

# JWT (Supabase Auth)
JwtSettings__Issuer=https://<project>.supabase.co/auth/v1
JwtSettings__Audience=authenticated
JwtSettings__Secret=<supabase-jwt-secret>

# CORS (origens do frontend, separadas por ;)
CORS__AllowedOrigins__0=http://localhost:3000
CORS__AllowedOrigins__1=http://localhost:5173

# Webhooks n8n (Story 1.4)
# Webhooks__N8nSecret=<secret>

# Opcional
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://+:8080
